---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import currently from '../data/currently.json';

const articles = (await getCollection('notebook', ({ data }) =>
  !data.draft && data.lang === 'es'
)).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);

const iconMap: Record<string, string> = {
  'book': 'assets/icons/book.svg',
  'television': 'assets/icons/television.svg',
  'film-slate': 'assets/icons/film-slate.svg',
  'microphone': 'assets/icons/microphone.svg',
  'headphones': 'assets/icons/headphones.svg',
};
---

<Base
  title="Felipe Aguilera · Estratega y escritor"
  description="Estratega de marca y comunicación. Escribiendo sobre cultura, tecnología y el oficio de hacer las cosas claras."
  lang="es"
>
  <div class="topbar"></div>

  <nav>
    <div class="wrap nav-in">
      <a class="logo" href="/es">
        <img src="/assets/mark-seal.svg" alt="Sello FA" />
        <span class="name">Felipe Aguilera</span>
      </a>
      <div class="nav-links">
        <a href="#notebook">Cuaderno</a>
        <a href="#work">Trabajo</a>
        <a href="#about">Sobre mí</a>
        <a href="/cv-es">CV</a>
        <span class="lang">
          <a href="/">EN</a>/<a href="/es" class="active">ES</a>
        </span>
        <a href="#hello" class="nav-cta">Escríbeme</a>
      </div>
    </div>
  </nav>

  <header class="hero">
    <div class="wrap narrow">
      <img class="seal" src="/assets/mark-seal.svg" alt="Sello FA" />
      <h1 class="mast">Felipe Aguilera</h1>
      <p class="mast-sub">Estratega de marca y comunicación.</p>
      <p class="mast-cred">Pensando en voz alta sobre cultura, tecnología y el oficio de hacer las cosas claras. Mitad cuaderno, mitad revista, enteramente mío.</p>
      <div class="cta-row">
        <a class="btn primary" href="#notebook">Leer el cuaderno</a>
        <a class="btn ghost" href="#about">Sobre mí</a>
      </div>
    </div>
  </header>

  <div class="section-bridge"><div class="fleuron"><span>&#10086;</span></div></div>

  <section class="cream" id="notebook">
    <div class="wrap">
      <div class="eyebrow">Cuaderno</div>
      <h2>Escritos <span class="o">recientes</span><span class="dot">.</span></h2>
      <p class="lead">Escribo sobre el cruce entre <strong>cultura, tecnología y marca</strong>, casi siempre partiendo de algo que no puedo dejar de pensar: una película, un lanzamiento, un pequeño cambio en cómo vivimos, y lo sigo hasta que dice algo útil. Me interesan menos las opiniones rápidas que <strong>pensar en voz alta y a la vista</strong>. Es como pienso, y la parte de la semana que más disfruto. Publico algo nuevo casi todos los viernes.</p>
      <div class="cards">
        {articles.map((article) => (
          <a class="card" href={`/es/notebook/${article.slug.replace(/^es\//, '')}`}>
            <div class="thumb">
              {article.data.cover && <img src={article.data.cover} alt={article.data.title} loading="lazy" />}
            </div>
            <div class="cbody">
              <span class="meta">{article.data.category}</span>
              <h3>{article.data.title}</h3>
              <p>{article.data.description}</p>
              <span class="more">Leer →</span>
            </div>
          </a>
        ))}
      </div>
      <div style="text-align:center;margin-top:30px;">
        <a class="btn ghost" href="/es/notebook">Todo el cuaderno →</a>
      </div>
    </div>
  </section>

  <section class="evo-home" id="hello">
    <div class="wrap">
      <div class="evo-home-inner">
        <div class="evo-home-left">
          <img src="/assets/EVO-logo-white.svg" alt="EVO Communication Lab" class="evo-home-logo" />
          <p class="evo-home-sub">Communication Lab</p>
        </div>
        <div class="evo-home-right">
          <div class="eyebrow evo-eyebrow">Trabajar juntos</div>
          <h2 class="evo-home-heading">Claridad sobre el ruido.<br/>Para empresas que necesitan comunicar mejor.</h2>
          <p class="evo-home-text">EVO construye sistemas de comunicación: identidad de marca, canales digitales y materiales que una empresa puede operar sola. Si tienes un proyecto, un problema, o simplemente quieres mejorar cómo comunica tu marca, por aquí se empieza.</p>
          <div class="evo-home-services">
            <div class="evo-service">
              <span class="evo-service-num">01</span>
              <div>
                <strong>Diagnóstico EVO</strong>
                <p>Sesión de 90 minutos más informe escrito. Qué funciona, qué no, y dónde concentrarse primero.</p>
              </div>
            </div>
            <div class="evo-service">
              <span class="evo-service-num">02</span>
              <div>
                <strong>Proyecto de alcance fijo</strong>
                <p>Entregable definido, precio fijo, plazo cerrado. Sin scope creep, sin horas abiertas.</p>
              </div>
            </div>
            <div class="evo-service">
              <span class="evo-service-num">03</span>
              <div>
                <strong>Retainer mensual</strong>
                <p>Horas dedicadas y soporte estratégico continuo. Para empresas que necesitan continuidad sin contratar internamente.</p>
              </div>
            </div>
          </div>
          <div class="cta-row" style="margin-top:36px; justify-content:flex-start;">
            <a class="btn primary" href="https://www.evo.cl/#contacto" target="_blank" rel="noopener">Iniciar una conversación</a>
            <a class="btn evo-ghost" href="https://www.evo.cl" target="_blank" rel="noopener">Cómo trabajamos →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="currently">
    <div class="wrap">
      <div class="eyebrow">Ahora mismo</div>
      <h2>Lo que me tiene <span class="o">ocupado</span><span class="dot">.</span></h2>
      <p class="lead">Un registro vivo de lo que leo, veo y escucho. Cambia seguido, ese es el punto.</p>
      <div class="nowgrid">
        <div class="nowcol">
          <span class="meta">Leyendo</span>
          <ul>
            {currently.reading.map((item) => (
              <li>
                <img class="ic" src={`/${iconMap[item.icon]}`} alt="" />
                <a href={item.url}>{item.title}</a> <em>&middot; {item.author}</em>
              </li>
            ))}
          </ul>
        </div>
        <div class="nowcol">
          <span class="meta">Viendo</span>
          <ul>
            {currently.watching.map((item) => (
              <li>
                <img class="ic" src={`/${iconMap[item.icon]}`} alt="" />
                <a href={item.url}>{item.title}</a> <em>&middot; {item.author}</em>
              </li>
            ))}
          </ul>
        </div>
        <div class="nowcol">
          <span class="meta">Escuchando</span>
          <ul>
            {currently.listening.map((item) => (
              <li>
                <img class="ic" src={`/${iconMap[item.icon]}`} alt="" />
                <a href={item.url}>{item.title}</a> <em>&middot; {item.author}</em>
              </li>
            ))}
          </ul>
        </div>
      </div>
      <p style="font-style:italic;color:var(--muted);font-size:14px;margin-top:18px;">Se actualiza seguido. Los links van a donde puedes encontrar cada uno, o a mi reseña si es que ya escribí una.</p>
    </div>
  </section>

  <section class="cream" id="work">
    <div class="wrap">
      <div class="eyebrow">Algunas cosas que hice</div>
      <h2>Del <span class="o">archivo</span><span class="dot">.</span></h2>
      <div class="cards">
        <div class="card">
          <div class="thumb"><img src="/assets/inzider.jpg" alt="Revista Inzider" loading="lazy" /></div>
          <div class="cbody"><span class="meta">Editorial &middot; 2014–2019</span><h3>Revista Inzider</h3><p>Una revista impresa que fundé y edité en Zmart: portadas, reportajes, publicidad, múltiples ediciones a lo largo de cinco años.</p></div>
        </div>
        <div class="card">
          <div class="thumb"><img src="/assets/zmart.jpg" alt="Zmart.cl" loading="lazy" /></div>
          <div class="cbody"><span class="meta">Marca y digital &middot; 2013–2024</span><h3>Zmart.cl</h3><p>Una década liderando la marca y la experiencia del cliente: omnicanalidad, lanzamientos de consolas y una cultura Great Place to Work.</p></div>
        </div>
        <div class="card">
          <div class="thumb"><img src="/assets/mifactoria.jpg" alt="Mi Factoria" loading="lazy" /></div>
          <div class="cbody"><span class="meta">Marca y Ecommerce &middot; 2024</span><h3>Mi Factoria</h3><p>Una marca y tienda Shopify: convertir una tienda funcional en una identidad coherente.</p></div>
        </div>
      </div>
    </div>
  </section>

  <section id="about">
    <div class="wrap">
      <div class="eyebrow">Quién soy</div>
      <div class="about">
        <div class="about-photo">
          <img class="portrait" src="/assets/portrait.png" alt="Felipe Aguilera" />
        </div>
        <div>
          <h2>Estratega de marca. <span class="o">Veinticinco años</span> haciendo las cosas claras<span class="dot">.</span></h2>
          <p class="lead dropcap">Lideré marketing y experiencia de cliente en <strong>Zmart</strong> por una década, y fundé y edité su revista, <strong>Inzider</strong>, en el camino. Antes, proyectos digitales para <strong>Metro de Santiago, Sodimac, Tetra Pak</strong> y <strong>Codelco</strong>. Hoy trabajo de forma independiente a través de <strong>EVO Communication Lab</strong>, en estrategia de marca, contenido y digital para clientes de distintos sectores. Estoy en Santiago, bilingüe, y hecho para el trabajo remoto. Escribo porque así pienso.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="background" class="cream">
    <div class="wrap">
      <div class="eyebrow">Trayectoria</div>
      <h2>El recorrido <span class="o">detrás del trabajo</span><span class="dot">.</span></h2>
      <div class="exp-list">
        <div class="exp-row">
          <div class="exp-row-meta">2024 &mdash; Hoy<br />EVO Communication Lab &middot; Remoto</div>
          <div class="exp-row-role">Fundador y Consultor Creativo<span>Estrategia de marca &middot; Contenido &middot; Digital &middot; Clientes en LATAM y Europa</span></div>
        </div>
        <div class="exp-row">
          <div class="exp-row-meta">2013 &mdash; 2024<br />Zmart Games &middot; Santiago</div>
          <div class="exp-row-role">Gerente de Marketing y Director UX<span>Una década. 25+ tiendas. La cadena líder de retail gaming y geek en Chile.</span></div>
        </div>
        <div class="exp-row">
          <div class="exp-row-meta">2005 &mdash; 2013<br />Elemento Media Design</div>
          <div class="exp-row-role">Director de Proyectos Digitales<span>Metro de Santiago &middot; Tetra Pak &middot; Suzuki &middot; Sodimac &middot; Codelco</span></div>
        </div>
        <div class="exp-row">
          <div class="exp-row-meta">1998 &mdash; 2005<br />Entel &middot; Lan-Z &middot; VEEgroup</div>
          <div class="exp-row-role">Primeros años: diseño, digital y marca<span>Contenido de marca &middot; Diseño multimedia &middot; Comunidades digitales</span></div>
        </div>
      </div>
      <div class="cta-row" style="margin-top:28px; justify-content:flex-start;">
        <a class="btn primary" href="https://www.linkedin.com/in/felipeaguilera" target="_blank" rel="noopener">LinkedIn →</a>
        <a class="btn ghost" href="/cv-es">CV completo (PDF) →</a>
      </div>
    </div>
  </section>

  <section class="brandstrip" id="record">
    <div class="wrap">
      <div class="eyebrow">En el camino</div>
      <div class="brandnames">Zmart &middot; Metro de Santiago &middot; Sodimac &middot; Tetra Pak &middot; Codelco &middot; Nintendo &middot; PlayStation &middot; Xbox</div>
    </div>
  </section>

  <footer>
    <div class="wrap">
      <div class="foot-orn">&#10086;</div>
      <div class="foot-in">
        <div>
          <a class="logo" href="/es">
            <img src="/assets/mark-seal-white.svg" alt="Sello FA" />
            <span class="name">Felipe Aguilera</span>
          </a>
          <p class="foot-tag">Estratega de oficio, curioso por naturaleza. Santiago, Chile.</p>
        </div>
        <div class="foot-links">
          <a href="/cv-es">CV</a>
          <a href="https://www.linkedin.com/in/felipeaguilera">LinkedIn</a>
          <a href="https://felipeaguilera.substack.com">Substack</a>
          <a href="mailto:felipe@faguilera.com">Email</a>
        </div>
      </div>
      <div class="foot-copy">&copy; 2026 Felipe Aguilera &middot; faguilera.com</div>
    </div>
  </footer>
</Base>
