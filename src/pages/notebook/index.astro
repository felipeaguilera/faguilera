---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('notebook', ({ data }) =>
  !data.draft && data.lang === 'en'
)).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const latest = articles.slice(0, 3);
const older  = articles.slice(3);

function fmt(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<Base
  title="Notebook · Felipe Aguilera"
  description="Essays on culture, technology, brand, and the craft of making things clear."
>
  <div class="topbar"></div>

  <nav>
    <div class="wrap nav-in">
      <a class="logo" href="/">
        <img src="/assets/mark-seal.svg" alt="FA seal" />
        <span class="name">Felipe Aguilera</span>
      </a>
      <div class="nav-links">
        <a href="/notebook" style="color:var(--ink);">Notebook</a>
        <a href="/#work">Work</a>
        <a href="/#about">About</a>
        <a href="/cv">CV</a>
        <span class="lang"><a href="/notebook" class="active">EN</a>/<a href="/es">ES</a></span>
        <a href="/#hello" class="nav-cta">Work together</a>
      </div>
    </div>
  </nav>

  <header class="nb-header">
    <div class="wrap narrow">
      <div class="eyebrow center-eyebrow">{articles.length} pieces</div>
      <h1 class="mast" style="font-size:52px;">Notebook</h1>
      <p class="lead" style="margin:0 auto;">On culture, technology, brand, and the craft of making things clear.</p>
    </div>
  </header>

  <!-- Latest: same 3-card row as homepage -->
  <section class="cream">
    <div class="wrap">
      <div class="eyebrow">Latest</div>
      <div class="cards">
        {latest.map((article) => (
          <a class="card" href={`/notebook/${article.slug}`}>
            {article.data.cover
              ? <img class="thumb" src={article.data.cover} alt={article.data.title} loading="lazy" />
              : <div class="thumb thumb-placeholder"></div>
            }
            <div class="cbody">
              <span class="meta">{article.data.category} &middot; {fmt(article.data.date)}</span>
              <h3>{article.data.title}</h3>
              <p>{article.data.description}</p>
              <span class="more">Read →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- All other articles -->
  <section>
    <div class="wrap">
      <div class="eyebrow">Archive</div>
      <div class="cards">
        {older.map((article) => (
          <a class="card" href={`/notebook/${article.slug}`}>
            {article.data.cover
              ? <img class="thumb" src={article.data.cover} alt={article.data.title} loading="lazy" />
              : <div class="thumb thumb-placeholder"></div>
            }
            <div class="cbody">
              <span class="meta">{article.data.category} &middot; {fmt(article.data.date)}</span>
              <h3>{article.data.title}</h3>
              <p>{article.data.description}</p>
              <span class="more">Read →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <footer>
    <div class="wrap">
      <div class="foot-orn">&#10086;</div>
      <div class="foot-in">
        <div>
          <a class="logo" href="/">
            <img src="/assets/mark-seal-white.svg" alt="FA seal" />
            <span class="name">Felipe Aguilera</span>
          </a>
          <p class="foot-tag">Strategist by trade, curious by nature. Santiago, Chile.</p>
        </div>
        <div class="foot-links">
          <a href="/cv">CV</a>
          <a href="https://www.linkedin.com/in/felipeaguilera">LinkedIn</a>
          <a href="https://felipeaguilera.substack.com">Substack</a>
          <a href="mailto:felipe@faguilera.com">Email</a>
        </div>
      </div>
      <div class="foot-copy">&copy; 2026 Felipe Aguilera &middot; faguilera.com</div>
    </div>
  </footer>
</Base>

<style>
  .nb-header {
    padding: 72px 0 52px;
    text-align: center;
    border-bottom: 1.5px solid var(--ink);
  }
  .center-eyebrow {
    justify-content: center;
    margin-bottom: 12px;
  }
  .center-eyebrow::before { display: none; }

  .thumb-placeholder { background: #e7e0d2; }
</style>
