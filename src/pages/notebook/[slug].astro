---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { netlifyImg, netlifyImgSrcset } from '../../utils/images.js';

export async function getStaticPaths() {
  const articles = await getCollection('notebook', ({ data }) => !data.draft && data.lang === 'en');
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();

const formattedDate = article.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const hasSyndication = article.data.substackUrl || article.data.mediumUrl || article.data.linkedinUrl;

// Check if an ES translation exists
const esArticles = await getCollection('notebook', ({ data }) => !data.draft && data.lang === 'es');
const hasEs = esArticles.some(a => a.slug === `es/${article.slug}`);
---

<Base
  title={`${article.data.title} · Felipe Aguilera`}
  description={article.data.description}
  image={article.data.cover}
  lang={article.data.lang}
>
  <div class="topbar"></div>

  <nav>
    <div class="wrap nav-in">
      <a class="logo" href="/">
        <img src="/assets/mark-seal.svg" alt="FA seal" />
        <span class="name">Felipe Aguilera</span>
      </a>
      <div class="nav-links">
        <a href="/#notebook">Notebook</a>
        <a href="/#work">Work</a>
        <a href="/#about">About</a>
        <a href="/cv">CV</a>
        <span class="lang">
          <a href={`/notebook/${article.slug}`} class="active">EN</a>/{hasEs ? <a href={`/es/notebook/${article.slug}`}>ES</a> : <span class="lang-na">ES</span>}
        </span>
        <a href="/#hello" class="nav-cta">Work together</a>
      </div>
    </div>
  </nav>

  {article.data.cover && (
    <div class="article-hero-wrap">
      <img
        src={netlifyImg(article.data.cover, { w: 1280 })}
        srcset={netlifyImgSrcset(article.data.cover, [640, 960, 1280, 1920, 2560])}
        sizes="(max-width: 1280px) 100vw, 1280px"
        alt={article.data.title}
        loading="eager"
        fetchpriority="high"
      />
    </div>
  )}

  <header class="article-header">
    <div class="wrap narrow">
      <div class="eyebrow">{article.data.category}</div>
      <h1 class="mast" style="font-size:52px;">{article.data.title}</h1>
      <p class="mast-sub">{article.data.description}</p>
      <p class="article-date">{formattedDate}</p>
    </div>
  </header>

  <div class="article-actions-bar">
    <div class="article-actions">
      <span class="aa-label">Read in</span>
      <a href={`/notebook/${article.slug}`} class="aa-btn active">EN</a>
      <span class="aa-sep">/</span>
      {hasEs
        ? <a href={`/es/notebook/${article.slug}`} class="aa-btn">ES</a>
        : <span class="aa-btn aa-disabled">ES</span>
      }
      <span class="aa-divider"></span>
      <span class="aa-label">Share</span>
      <button class="aa-btn" onclick="window.print()" title="Print / Save as PDF">
        <img src="/assets/icons/printer.svg" class="aa-icon" alt="Print" />
      </button>
      <a class="aa-btn" id="share-x" href="#" target="_blank" rel="noopener" title="Share on X">
        <img src="/assets/icons/x-logo.svg" class="aa-icon" alt="X" />
      </a>
      <a class="aa-btn" id="share-li" href="#" target="_blank" rel="noopener" title="Share on LinkedIn">
        <img src="/assets/icons/linkedin-logo.svg" class="aa-icon" alt="LinkedIn" />
      </a>
      <a class="aa-btn" id="share-wa" href="#" target="_blank" rel="noopener" title="Share on WhatsApp">
        <img src="/assets/icons/whatsapp-logo.svg" class="aa-icon" alt="WhatsApp" />
      </a>
      <button class="aa-btn" id="copy-url" title="Copy link">
        <img src="/assets/icons/link.svg" class="aa-icon" id="copy-icon" alt="Copy link" />
        <span id="copy-check" style="display:none;font-size:12px;">✓</span>
      </button>
    </div>
  </div>
  <script>
  (function(){
    var u=encodeURIComponent(window.location.href);
    var t=encodeURIComponent(document.title);
    document.getElementById('share-x').href='https://twitter.com/intent/tweet?url='+u+'&text='+t;
    document.getElementById('share-li').href='https://www.linkedin.com/sharing/share-offsite/?url='+u;
    document.getElementById('share-wa').href='https://api.whatsapp.com/send?text='+t+'%20'+u;
    var c=document.getElementById('copy-url');
    c.addEventListener('click',function(){
      navigator.clipboard.writeText(window.location.href).then(function(){
        document.getElementById('copy-icon').style.display='none';
        document.getElementById('copy-check').style.display='inline';
        setTimeout(function(){
          document.getElementById('copy-icon').style.display='';
          document.getElementById('copy-check').style.display='none';
        },1800);
      }).catch(function(){});
    });
    // Inject print links for video embeds
    document.querySelectorAll('.video-embed').forEach(function(el){
      var iframe=el.querySelector('iframe');
      if(!iframe) return;
      var src=iframe.getAttribute('src')||'';
      var m=src.match(/embed\/([^?]+)/);
      if(!m) return;
      var a=document.createElement('a');
      a.href='https://youtube.com/watch?v='+m[1];
      a.className='video-print-link';
      a.textContent='Video: youtube.com/watch?v='+m[1];
      el.parentNode.insertBefore(a,el.nextSibling);
    });
  })();
  </script>

  <section class="article-body">
    <div class="wrap">
      <div class="prose">
        <Content />
      </div>
      {hasSyndication && (
        <div class="syndication-note">
          Also published on:
          {article.data.substackUrl && <a href={article.data.substackUrl} target="_blank" rel="noopener">Substack</a>}
          {article.data.substackUrl && article.data.mediumUrl && ' · '}
          {article.data.mediumUrl && <a href={article.data.mediumUrl} target="_blank" rel="noopener">Medium</a>}
          {(article.data.substackUrl || article.data.mediumUrl) && article.data.linkedinUrl && ' · '}
          {article.data.linkedinUrl && <a href={article.data.linkedinUrl} target="_blank" rel="noopener">LinkedIn</a>}
        </div>
      )}
    </div>
  </section>

  <section class="evo-cta">
    <div class="wrap">
      <div class="evo-cta-inner">
        <div class="evo-cta-logo">
          <img src="/assets/EVO-logo-white.svg" alt="EVO Communication Lab" />
        </div>
        <div class="evo-cta-body">
          <p class="evo-cta-tag">Communication Lab</p>
          <h2 class="evo-cta-heading">Got a project? Let's talk.</h2>
          <p class="evo-cta-text">EVO builds communication systems for businesses: brand identity, digital channels, and materials that work on their own. If something in this piece sparked an idea — or you've just been meaning to fix how your business communicates — this is the place to start.</p>
          <div class="evo-cta-actions">
            <a class="btn primary" href="https://www.evo.cl/#contacto" target="_blank" rel="noopener">Start a conversation</a>
            <a class="btn evo-ghost" href="https://www.evo.cl" target="_blank" rel="noopener">See how we work →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <footer>
    <div class="wrap">
      <div class="foot-orn">&#10086;</div>
      <div class="foot-in">
        <div>
          <a class="logo" href="/">
            <img src="/assets/mark-seal-white.svg" alt="FA seal" />
            <span class="name">Felipe Aguilera</span>
          </a>
          <p class="foot-tag">Strategist by trade, curious by nature. Santiago, Chile.</p>
        </div>
        <div class="foot-links">
          <a href="/cv">CV</a>
          <a href="https://www.linkedin.com/in/felipeaguilera">LinkedIn</a>
          <a href="https://felipeaguilera.substack.com">Substack</a>
          <a href="mailto:felipe@faguilera.com">Email</a>
        </div>
      </div>
      <div class="foot-copy">&copy; 2026 Felipe Aguilera &middot; faguilera.com</div>
    </div>
  </footer>
</Base>
