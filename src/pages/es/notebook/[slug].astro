---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('notebook', ({ data }) => !data.draft && data.lang === 'es');
  return articles.map((article) => ({
    params: { slug: article.slug.replace(/^es\//, '') },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();
const cleanSlug = article.slug.replace(/^es\//, '');

const formattedDate = article.data.date.toLocaleDateString('es-CL', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const hasSyndication = article.data.substackUrl || article.data.mediumUrl || article.data.linkedinUrl;

// Check if EN version exists
const enArticles = await getCollection('notebook', ({ data }) => !data.draft && data.lang === 'en');
const hasEn = enArticles.some(a => a.slug === cleanSlug);
---

<Base
  title={`${article.data.title} · Felipe Aguilera`}
  description={article.data.description}
  image={article.data.cover}
  lang="es"
>
  <div class="topbar"></div>

  <nav>
    <div class="wrap nav-in">
      <a class="logo" href="/es">
        <img src="/assets/mark-seal.svg" alt="Sello FA" />
        <span class="name">Felipe Aguilera</span>
      </a>
      <div class="nav-links">
        <a href="/es#notebook">Cuaderno</a>
        <a href="/es#work">Trabajo</a>
        <a href="/es#about">Sobre mí</a>
        <a href="/cv-es">CV</a>
        <span class="lang">
          {hasEn ? <a href={`/notebook/${cleanSlug}`}>EN</a> : <span class="lang-na">EN</span>}/<a href={`/es/notebook/${cleanSlug}`} class="active">ES</a>
        </span>
        <a href="/es#hello" class="nav-cta">Escríbeme</a>
      </div>
    </div>
  </nav>

  {article.data.cover && (
    <div class="article-hero-wrap">
      <img src={article.data.cover} alt={article.data.title} />
    </div>
  )}

  <header class="article-header">
    <div class="wrap narrow">
      <div class="eyebrow">{article.data.category}</div>
      <h1 class="mast" style="font-size:52px;">{article.data.title}</h1>
      <p class="mast-sub">{article.data.description}</p>
      <p class="article-date">{formattedDate}</p>
    </div>
  </header>

  <div class="article-actions-bar">
    <div class="article-actions">
      <span class="aa-label">Leer en</span>
      {hasEn
        ? <a href={`/notebook/${cleanSlug}`} class="aa-btn">EN</a>
        : <span class="aa-btn aa-disabled">EN</span>
      }
      <span class="aa-sep">/</span>
      <a href={`/es/notebook/${cleanSlug}`} class="aa-btn active">ES</a>
      <span class="aa-divider"></span>
      <span class="aa-label">Compartir</span>
      <button class="aa-btn" onclick="window.print()" title="Imprimir / Guardar como PDF">
        <img src="/assets/icons/printer.svg" class="aa-icon" alt="Imprimir" />
      </button>
      <a class="aa-btn" id="share-x" href="#" target="_blank" rel="noopener" title="Compartir en X">
        <img src="/assets/icons/x-logo.svg" class="aa-icon" alt="X" />
      </a>
      <a class="aa-btn" id="share-li" href="#" target="_blank" rel="noopener" title="Compartir en LinkedIn">
        <img src="/assets/icons/linkedin-logo.svg" class="aa-icon" alt="LinkedIn" />
      </a>
      <a class="aa-btn" id="share-wa" href="#" target="_blank" rel="noopener" title="Compartir en WhatsApp">
        <img src="/assets/icons/whatsapp-logo.svg" class="aa-icon" alt="WhatsApp" />
      </a>
      <button class="aa-btn" id="copy-url" title="Copiar enlace">
        <img src="/assets/icons/link.svg" class="aa-icon" id="copy-icon" alt="Copiar enlace" />
        <span id="copy-check" style="display:none;font-size:12px;">✓</span>
      </button>
    </div>
  </div>
  <script>
  (function(){
    var u=encodeURIComponent(window.location.href);
    var t=encodeURIComponent(document.title);
    document.getElementById('share-x').href='https://twitter.com/intent/tweet?url='+u+'&text='+t;
    document.getElementById('share-li').href='https://www.linkedin.com/sharing/share-offsite/?url='+u;
    document.getElementById('share-wa').href='https://api.whatsapp.com/send?text='+t+'%20'+u;
    var c=document.getElementById('copy-url');
    c.addEventListener('click',function(){
      navigator.clipboard.writeText(window.location.href).then(function(){
        document.getElementById('copy-icon').style.display='none';
        document.getElementById('copy-check').style.display='inline';
        setTimeout(function(){
          document.getElementById('copy-icon').style.display='';
          document.getElementById('copy-check').style.display='none';
        },1800);
      }).catch(function(){});
    });
    // Inyectar links de impresión para videos
    document.querySelectorAll('.video-embed').forEach(function(el){
      var iframe=el.querySelector('iframe');
      if(!iframe) return;
      var src=iframe.getAttribute('src')||'';
      var m=src.match(/embed\/([^?]+)/);
      if(!m) return;
      var a=document.createElement('a');
      a.href='https://youtube.com/watch?v='+m[1];
      a.className='video-print-link';
      a.textContent='Video: youtube.com/watch?v='+m[1];
      el.parentNode.insertBefore(a,el.nextSibling);
    });
  })();
  </script>

  <section class="article-body">
    <div class="wrap">
      <div class="prose">
        <Content />
      </div>
      {hasSyndication && (
        <div class="syndication-note">
          También publicado en:
          {article.data.substackUrl && <a href={article.data.substackUrl} target="_blank" rel="noopener">Substack</a>}
          {article.data.substackUrl && article.data.mediumUrl && ' · '}
          {article.data.mediumUrl && <a href={article.data.mediumUrl} target="_blank" rel="noopener">Medium</a>}
          {(article.data.substackUrl || article.data.mediumUrl) && article.data.linkedinUrl && ' · '}
          {article.data.linkedinUrl && <a href={article.data.linkedinUrl} target="_blank" rel="noopener">LinkedIn</a>}
        </div>
      )}
    </div>
  </section>

  <section class="evo-cta">
    <div class="wrap">
      <div class="evo-cta-inner">
        <div class="evo-cta-logo">
          <img src="/assets/EVO-logo-white.svg" alt="EVO Creative Lab" />
        </div>
        <div class="evo-cta-body">
          <p class="evo-cta-tag">Communication Lab</p>
          <h2 class="evo-cta-heading">¿Tienes un proyecto? Hablemos.</h2>
          <p class="evo-cta-text">EVO construye sistemas de comunicación para empresas: identidad de marca, canales digitales y materiales que funcionan solos. Si algo en este artículo te generó una idea, o simplemente llevas tiempo queriendo mejorar cómo comunica tu negocio, por aquí se empieza.</p>
          <div class="evo-cta-actions">
            <a class="btn primary" href="https://www.evo.cl/#contacto" target="_blank" rel="noopener">Iniciar una conversación</a>
            <a class="btn evo-ghost" href="https://www.evo.cl" target="_blank" rel="noopener">Cómo trabajamos →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <footer>
    <div class="wrap">
      <div class="foot-orn">&#10086;</div>
      <div class="foot-in">
        <div>
          <a class="logo" href="/es">
            <img src="/assets/mark-seal-white.svg" alt="Sello FA" />
            <span class="name">Felipe Aguilera</span>
          </a>
          <p class="foot-tag">Estratega de oficio, curioso por naturaleza. Santiago, Chile.</p>
        </div>
        <div class="foot-links">
          <a href="/cv-es">CV</a>
          <a href="https://www.linkedin.com/in/felipeaguilera">LinkedIn</a>
          <a href="https://felipeaguilera.substack.com">Substack</a>
          <a href="mailto:felipe@faguilera.com">Email</a>
        </div>
      </div>
      <div class="foot-copy">&copy; 2026 Felipe Aguilera &middot; faguilera.com</div>
    </div>
  </footer>
</Base>
